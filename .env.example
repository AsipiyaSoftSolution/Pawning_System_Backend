# Server (5000 — Account Center PAWNING_SYSTEM_API_URL)
PORT=5000
NODE_ENV=development

# Pawning frontend origin for CORS and password-reset links
CLIENT_URL=http://localhost:5176

# Primary MySQL (pawning)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=pawning_system
DB_PORT=3306
DB_SSL=false

# Secondary MySQL (often shared / reporting DB)
DB2_HOST=localhost
DB2_USER=root
DB2_PASSWORD=
DB2_NAME=account_center_asipiya
DB2_PORT=3306
DB2_SSL=false

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Account Center API base URL (no trailing slash)
ACCOUNT_CENTER_API_URL=http://localhost:8000/api
